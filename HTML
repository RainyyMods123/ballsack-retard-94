<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test Page</title>
    <style>
        /* Step 1: Reset default margins and set full viewport height */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Step 2: Apply blue background to the entire page */
        body {
            background-color: #1a73e8; /* solid blue, you can change to any blue shade */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: Arial, Helvetica, sans-serif;
        }

        /* Step 3: Style the text container */
        .container {
            background-color: rgba(255, 255, 255, 0.9); /* semi-transparent white for contrast */
            padding: 2rem 3rem;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            text-align: center;
        }

        /* Step 4: Style the main text */
        h1 {
            font-size: 3rem;
            color: #0a2a4a;
            letter-spacing: 1px;
            font-weight: 700;
            margin: 0;
        }

        /* Step 5: (Optional) add a subtle text shadow for readability */
        h1 {
            text-shadow: 1px 1px 2px rgba(255,255,255,0.5);
        }
    </style>
</head>
<body>
    <!-- Step 6: The actual content – "this is a test" in the middle -->
    <div class="container">
        <h1>this is a test</h1>
    </div>
</body>
</html>
